rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "madnan08122@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidString(text, maxLen) {
      return text is string && text.size() <= maxLen;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                    request.resource.data.role == 'user' &&
                    isValidString(request.resource.data.name, 100) &&
                    isValidString(request.resource.data.email, 100);
      allow update: if isOwner(userId) && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email']) || isAdmin());
      allow delete: if isAdmin();

      match /metrics/{metricId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if false;
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /onboarding/{onboardingId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if false;
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /leads/{leadId} {
      allow create: if isValidString(request.resource.data.name, 100) &&
                       isValidString(request.resource.data.email, 100) &&
                       isValidString(request.resource.data.phone, 20) &&
                       isValidString(request.resource.data.interest, 100);
      allow read, update, delete: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /content/site {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
